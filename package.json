{
  "name": "quarkcss",
  "version": "0.0.0",
  "private": true,
  "author": "Chris Pakken",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "up": "pnpm dlx npm-check-updates --root -ws -i",
    "build": "turbo build",
    "b": "bun run --filter '*' b",
    "test": "bun run --filter '*' test",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo typecheck",
    "tc": "turbo typecheck",
    "publish-packages": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.55.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.0",
  "trustedDependencies": [
    "oxfmt",
    "esbuild"
  ]
}
