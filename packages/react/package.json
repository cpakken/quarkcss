{
  "name": "@quarkcss/react",
  "version": "1.0.0-beta.3",
  "keywords": [
    "atomiccss",
    "css",
    "react",
    "styled-components",
    "tailwindcss"
  ],
  "license": "MIT",
  "author": "Chris Pakken",
  "repository": {
    "type": "git",
    "url": "https://github.com/cpakken/quarkcss/tree/master/packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./merge": {
      "types": "./dist/merge.d.ts",
      "import": "./dist/merge.js"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "test": "vitest --globals",
    "t": "vitest --globals",
    "typecheck": "tsc --noEmit --pretty false",
    "tc": "tsc --noEmit --pretty false",
    "build": "tsdown",
    "b": "tsdown"
  },
  "dependencies": {
    "@quarkcss/core": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3",
    "tsdown": "^0.22.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "tailwind-merge": "^3"
  },
  "peerDependenciesMeta": {
    "tailwind-merge": {
      "optional": true
    }
  },
  "//main": "src/index.ts",
  "//module": "src/index.ts"
}
